# AI Configuration
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
OPENROUTER_API_KEY=...

# Portainer / Deployment Configuration
# Set DATA_DIR to the absolute path on your host (e.g. /home/colacho/docker/faragopedia)
DATA_DIR=.
# Set PUID and PGID to match your host user (run 'id' to find them)
PUID=1000
PGID=1000

# Port Configuration (change if ports 8300 or 5173 are already in use)
BACKEND_PORT=8300
FRONTEND_PORT=5173

# Frontend Configuration
VITE_ALLOWED_HOST=...
VITE_API_BASE_URL=http://localhost:8300
