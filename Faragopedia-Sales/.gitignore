# =============================================================================
# Faragopedia-Sales .gitignore
# =============================================================================

# -- Dependencies --
node_modules/
vendor/
.pnp
.pnp.js

# -- Build output --
dist/
build/
out/
.next/
.nuxt/
.output/

# -- Environment & secrets --
.env
.env.local
.env.*.local

# -- OS files --
.DS_Store
Thumbs.db
Desktop.ini

# -- Editor / IDE --
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# -- Logs --
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# -- Testing --
coverage/
.nyc_output/

# -- Docker --
# Don't ignore Dockerfile or docker-compose.yml (they should be committed)
# But ignore runtime data
docker-data/

# -- AI agent working files (agent-specific, NOT shared context) --
# Shared context files (AGENTS.md, CLAUDE.md, GEMINI.md) ARE committed.
# Agent-local caches and memory should be ignored:
.claude/
.gemini/

# -- Python --
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/

# -- Runtime Data --
wiki/
sources/
snapshots/
archive/
schema/wiki_config.json
schema/company_profile.md
schema/SCHEMA.md
schema/SCHEMA_TEMPLATE.md

# -- Misc --
*.tgz
*.tar.gz
.cache/
tmp/
