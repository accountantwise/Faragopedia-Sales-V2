# =============================================================================
# Faragopedia-V2 .gitignore
# =============================================================================

# -- Dependencies --
node_modules/
vendor/
.pnp
.pnp.js

# -- Build output --
dist/
build/
out/
.next/
.nuxt/
.output/

# -- Environment & secrets --
.env
.env.local
.env.*.local

# -- OS files --
.DS_Store
Thumbs.db
Desktop.ini

# -- Editor / IDE --
.vscode/
.idea/
*.swp
*.swo
*~

# -- Logs --
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# -- Testing --
coverage/
.nyc_output/
.pytest_cache/

# -- Docker --
docker-data/

# -- AI agent working files --
.claude/
.gemini/
.superpowers/

# -- Misc --
*.tgz
*.tar.gz
.cache/
tmp/
.worktrees/
